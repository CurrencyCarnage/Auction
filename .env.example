# Demo/default mode
DEMO_MODE=true
STORAGE_DRIVER=json
PORT=4173
DATA_DIR=./data

# Set stable secrets on any shared deployment.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-a-long-random-secret
ADMIN_SESSION_TOKEN=change-me-generate-a-long-random-token

# Demo admin fallback credentials. Replace before any non-demo use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# PostgreSQL staging/prod mode
# STORAGE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host:5432/dbname
# PGSSLMODE=require
